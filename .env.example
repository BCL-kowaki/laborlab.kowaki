# ========================================
# 小脇社会保険労務士事務所 公式サイト
# 環境変数テンプレート
# ========================================
# このファイルをコピーして .env.local を作成してください:
#   cp .env.example .env.local
# ========================================

# ----------------------------------------
# サイトURL
# ----------------------------------------
# OGP、sitemap.xml などで使用されます
NEXT_PUBLIC_SITE_URL=https://laborlab.kowackey.com

# ----------------------------------------
# Resend（お問い合わせフォーム通知）
# ----------------------------------------
# https://resend.com でAPIキー取得
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# お問い合わせ通知の送信先（事務所のメール）
CONTACT_EMAIL_TO=info@laborlab.kowackey.com

# 送信元アドレス（ドメイン認証済みであること）
CONTACT_EMAIL_FROM=noreply@laborlab.kowackey.com

# ----------------------------------------
# Cloudflare Turnstile（スパム対策）
# ----------------------------------------
# https://www.cloudflare.com/products/turnstile/ でサイトキー取得
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------
# Google Analytics 4（任意）
# ----------------------------------------
# 使用する場合のみ設定
NEXT_PUBLIC_GA_ID=

# ----------------------------------------
# Vercel Analytics（自動）
# ----------------------------------------
# Vercel デプロイ時に自動設定されます

# ----------------------------------------
# 開発環境用
# ----------------------------------------
# 開発サーバーのポート（デフォルト3000）
# PORT=3000
