# ========================================
# 小脇社会保険労務士事務所 公式サイト
# 環境変数テンプレート
# ========================================
# このファイルをコピーして .env.local を作成してください:
#   cp .env.example .env.local
# ========================================

# ----------------------------------------
# サイトURL
# ----------------------------------------
# OGP、sitemap.xml などで使用されます
NEXT_PUBLIC_SITE_URL=https://laborlab.kowackey.com

# ----------------------------------------
# お問い合わせフォーム（GAS + スプレッドシート）
# ----------------------------------------
# セットアップ手順は docs/contact-form-setup.md を参照
# GAS Web App の公開URL（https://script.google.com/macros/s/.../exec）
GAS_WEBHOOK_URL=

# GAS 側と Next.js 側で一致させる共有トークン（任意の長い文字列）
# 生成例: openssl rand -hex 32
GAS_SHARED_TOKEN=

# ----------------------------------------
# Cloudflare Turnstile（任意・スパム対策強化用）
# ----------------------------------------
# 現状は honeypot で十分。必要になったら有効化。
# https://www.cloudflare.com/products/turnstile/ でサイトキー取得
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------
# Google Analytics 4（任意）
# ----------------------------------------
# 使用する場合のみ設定
NEXT_PUBLIC_GA_ID=

# ----------------------------------------
# Vercel Analytics（自動）
# ----------------------------------------
# Vercel デプロイ時に自動設定されます

# ----------------------------------------
# 開発環境用
# ----------------------------------------
# 開発サーバーのポート（デフォルト3000）
# PORT=3000
